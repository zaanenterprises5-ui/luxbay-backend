# Example environment variables for Luxbay backend
# Do NOT commit real secrets to the repo. Use this as a template.

PORT=5002
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/your-db
BASE_API_URL=https://api.your-domain.com/api
CLIENT_URL=https://luxbay-admin.vercel.app
JWT_SECRET=your_jwt_secret_here

# Cloudinary (if used)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional: for third-party services
MAILGUN_API_KEY=
MAILCHIMP_KEY=

# Set to 'true' when running on Vercel (or set appropriate env in your host)
VERCEL=false

# Host binding override for cloud hosts (default 0.0.0.0)
HOST=0.0.0.0
